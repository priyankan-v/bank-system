<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="TOP_CENTER" prefWidth="1100" style="-fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bank.controller.AdminActivity">

    <!-- TITLE -->
    <Label text="Activity Logs" style="-fx-font-size: 18; -fx-font-weight: bold;" alignment="CENTER"/>

    <!-- ERROR MESSAGE -->
    <VBox fx:id="errorBox" 
       spacing="8" 
       alignment="CENTER" 
       visible="false" 
       managed="false"
       maxWidth="800"
       style="-fx-padding: 10; -fx-border-color: #ff6b6b; -fx-background-color: #ffe0e0; -fx-border-radius: 5; -fx-background-radius: 5;">
        <Label fx:id="errorLabel"
               style="-fx-font-weight: bold; -fx-text-fill: #d9534f; -fx-wrap-text: true;" 
               alignment="CENTER"
               wrapText="true"/>
    </VBox>

    <!-- TABS FOR ACTIVITY LOGS -->
    <TabPane fx:id="activityTabPane" tabClosingPolicy="UNAVAILABLE" prefHeight="600">
        
        <!-- TAB 1: MY ACTIVITY -->
        <Tab text="Admin Logs">
            <VBox spacing="10" style="-fx-padding: 10;">
                
                <!-- Filter Controls for Admin Activity -->
                <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10; -fx-border-color: #e0e0e0; -fx-background-color: #f9f9f9; -fx-border-radius: 3;">
                    <Label text="Limit:" style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="adminLimitCombo" prefWidth="120" onAction="#onAdminLimitChanged"/>

                    <!-- Date Picker for Admin Activity (hidden by default) -->
                    <DatePicker fx:id="adminDatePicker" 
                                visible="false" 
                                managed="false"
                                onAction="#onAdminDateSelected"/>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <Label fx:id="adminActivityCountLabel" 
                           style="-fx-font-weight: bold; -fx-text-fill: #27ae60; -fx-font-size: 11;"/>
                </HBox>

                <!-- Admin Activity Table -->
                <TableView fx:id="adminActivityTable"
                           prefHeight="450"
                           style="-fx-font-size: 11;">
                    <columns>
                        <TableColumn fx:id="adminDateColumn" text="Date" prefWidth="160">
                            <cellValueFactory>
                                <PropertyValueFactory property="createdAt"/>
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Target Admin" prefWidth="100" style="-fx-alignment: CENTER;">
                            <cellValueFactory>
                                <PropertyValueFactory property="targetId"/>
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Action" prefWidth="160" style="-fx-alignment: CENTER;">
                            <cellValueFactory>
                                <PropertyValueFactory property="event"/>
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Details" prefWidth="250">
                            <cellValueFactory>
                                <PropertyValueFactory property="description"/>
                            </cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>

            </VBox>
        </Tab>

        <!-- TAB 2: USER ACTIVITY -->
        <Tab text="User Logs">
            <VBox spacing="10" style="-fx-padding: 10;">
                
                <!-- Filter Controls for User Activity -->
                <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10; -fx-border-color: #e0e0e0; -fx-background-color: #f9f9f9; -fx-border-radius: 3;">
                    <Label text="Limit:" style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="userLimitCombo" prefWidth="120" onAction="#onUserLimitChanged"/>

                    <!-- Date Picker for User Activity (hidden by default) -->
                    <DatePicker fx:id="userDatePicker" 
                                visible="false" 
                                managed="false"
                                onAction="#onUserDateSelected"/>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <Label fx:id="userActivityCountLabel" 
                           style="-fx-font-weight: bold; -fx-text-fill: #27ae60; -fx-font-size: 11;"/>
                </HBox>

                <!-- User Audit Activity Table -->
                <TableView fx:id="userActivityTable" prefHeight="450" style="-fx-font-size: 11;">
                    <columns>
                        <TableColumn fx:id="userDateColumn" text="Date" prefWidth="160">
                            <cellValueFactory>
                                <PropertyValueFactory property="createdAt"/>
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Account Number" prefWidth="120" style="-fx-alignment: CENTER;">
                            <cellValueFactory>
                                <PropertyValueFactory property="accountNumber"/>
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Action" prefWidth="160" style="-fx-alignment: CENTER;">
                            <cellValueFactory>
                                <PropertyValueFactory property="event"/>
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Details" prefWidth="250">
                            <cellValueFactory>
                                <PropertyValueFactory property="description"/>
                            </cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>

            </VBox>
        </Tab>

    </TabPane>

    <!-- REFRESH AND BACK BUTTONS -->
    <HBox spacing="15" alignment="CENTER" style="-fx-padding-top: 10;">
        <Button text="🔄 Refresh"
                onAction="#refreshActivity"
                prefWidth="120"
                prefHeight="35"
                style="-fx-font-size: 11;"/>
        <Button text="Back to Dashboard"
                onAction="#goBack"
                prefWidth="150"
                prefHeight="35"
                style="-fx-font-size: 11;"/>
    </HBox>

</VBox>


<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane alignment="CENTER"
          hgap="10"
          vgap="15"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.bank.controller.AdminLoginController">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Admin Login"
           style="-fx-font-size:20px"
           GridPane.columnSpan="2"
           GridPane.rowIndex="0"
           GridPane.halignment="CENTER"/>

    <Region GridPane.rowIndex="1" minHeight="10"/>

    <Label text="Enter Username :" GridPane.rowIndex="2"/>
    <TextField fx:id="usernameField"
               promptText="Username"
               GridPane.columnIndex="1"
               GridPane.rowIndex="2"/>

    <Label text="Enter Password :" GridPane.rowIndex="3"/>
    <PasswordField fx:id="passwordField"
                   promptText="Password"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="3"/>

    <Region GridPane.rowIndex="4" minHeight="10"/>

    <Button text="Login"
            onAction="#handleLogin"
            GridPane.columnSpan="2"
            GridPane.rowIndex="5"
            GridPane.halignment="CENTER"/>

    <Region GridPane.rowIndex="6" minHeight="10"/>

    <Label fx:id="messageLabel"
           textFill="red"
           GridPane.columnSpan="2"
           GridPane.rowIndex="7"
           GridPane.halignment="CENTER"/>

</GridPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane alignment="CENTER"
          hgap="10"
          vgap="15"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.bank.controller.AdminPasswordChangeController">

    <Label text="Change Password"
           style="-fx-font-size:20px"
           GridPane.columnSpan="2"
           GridPane.rowIndex="0"
           GridPane.halignment="CENTER"/>

    <Label text="Enter Current Password :" GridPane.rowIndex="1"/>
    <PasswordField fx:id="oldPasswordField"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="1"/>

    <Label text="Enter New Password :" GridPane.rowIndex="2"/>
    <PasswordField fx:id="newPasswordField"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="2"/>

    <Label text="Confirm New Password :" GridPane.rowIndex="3"/>
    <PasswordField fx:id="confirmPasswordField"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="3"/>

    <Button text="Change Password"
            onAction="#changePassword"
            GridPane.columnSpan="2"
            GridPane.rowIndex="4"
            GridPane.halignment="CENTER"/>

    <Label fx:id="messageLabel"
           GridPane.columnSpan="2"
           GridPane.rowIndex="5"
           GridPane.halignment="CENTER"/>

    <Button text="Back"
            onAction="#back"
            GridPane.columnSpan="2"
            GridPane.rowIndex="6"
            GridPane.halignment="CENTER"/>

</GridPane>